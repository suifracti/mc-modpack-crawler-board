# Python runtime cache
__pycache__/
*.py[cod]
*$py.class

# OS generated files
.DS_Store
Thumbs.db

# Local editor / assistant state. These help this machine only; they are not
# crawler/converter source files.
.vscode/
pyrightconfig.json

# Codex/Gemini/agent working notes. These are local work logs, not project files.
.agents/

# Local-only files moved out of the Git-managed project surface:
# - browser_data/ contains Playwright/Chromium profile state, cookies and cache.
# - 归档/ contains old scratch/backup scripts kept only for reference.
ignored_local_files/

# Common temporary outputs
*.tmp
*.bak
*.log

# Local crawler snapshots can grow beyond GitHub's file limit.  The crawler and
# converter still use this path locally; Git keeps code and long-term trends.
多平台爬虫数据_v1.0.jsonl

# Generated dashboards are local artifacts.  Versioned copies and run logs are local.
多平台聚合看板_V1.0.html
多平台聚合看板_V1.0_v*.html
多平台聚合看板_V1.0_data/
